      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "mpesa-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select\n                  transaction_date,\n                  count(*) as staged_transactions,\n                  count(*) filter (where customer_phone_number is null) as missing_phone,\n                  count(*) filter (where transaction_amount is null) as missing_amount,\n                  count(*) filter (where account_reference is null) as missing_reference\n                from public_staging.stg_c2b_transactions\n                where transaction_date >= current_date - interval '14 days'\n                group by 1\n                order by 1 desc",
          "refId": "A"
        }
      ],
      "title": "Daily Completeness",
      "type": "table"
